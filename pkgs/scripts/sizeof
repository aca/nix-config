#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
	echo "usage: $(basename "$0") <file>" >&2
	exit 1
fi

file=$1

if [ ! -e "$file" ]; then
	echo "error: $file does not exist" >&2
	exit 1
fi

case "$(uname -s)" in
	Darwin|*BSD) stat -f%z "$file" ;;
	*)           stat -c%s "$file" ;;
esac
