#!/usr/bin/env bash
# 비디오 → SVT-AV1 (작은 용량 + 원본 화질 유지)
# 사용법: encode-av1 [-d|--delete] INPUT [PRESET]

set -euxo pipefail

DELETE_SOURCE=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
    -d|--delete) DELETE_SOURCE=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done

INPUT_PATH="${ARGS[0]}"
PRESET="${ARGS[1]:-6}"
cd "$(dirname "$INPUT_PATH")"
INPUT="$(basename "$INPUT_PATH")"
OUTPUT="${INPUT%.*}.av1.mp4"

# 파일명이 이미 .av1.mp4면 스킵
case "$INPUT" in
  *.av1.mp4)
    echo "이미 .av1.mp4 파일입니다 ($INPUT). 스킵."
    exit 0
    ;;
esac

# 출력 파일이 이미 있으면 스킵
if [ -f "$OUTPUT" ]; then
  echo "이미 인코딩된 파일이 있습니다 ($OUTPUT). 스킵."
  exit 0
fi

# 입력이 이미 AV1 코덱이면 스킵
INPUT_CODEC="$(ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$INPUT")"
if [ "$INPUT_CODEC" = "av1" ]; then
  echo "이미 AV1 코덱입니다 ($INPUT). 인코딩 스킵."
  exit 0
fi

ffmpeg \
  -threads 2 \
  -i "$INPUT" \
  `# libsvtav1: Intel/Netflix의 SVT-AV1 인코더` \
  -c:v libsvtav1 \
  `# CRF: 화질 기준 가변 비트레이트 (0~63, 낮을수록 고화질·큰 용량)` \
  `# SVT-AV1에서 23~28이 시각적 무손실 영역` \
  -crf 23 \
  `# preset: 압축 효율↔속도 트레이드오프 (0=최고압축·느림, 13=빠름)` \
  -preset "$PRESET" \
  `# yuv420p10le: 10-bit 인코딩으로 밴딩↓ + 압축효율 ~5%↑` \
  -pix_fmt yuv420p10le \
  `# tune=0: 시각 품질 최적화 / film-grain=8: 그레인 합성으로 용량↓` \
  -svtav1-params "tune=0:film-grain=8" \
  `# libopus: 가장 효율적인 오디오 코덱 (AAC 대비 ~30% 효율↑)` \
  -c:a libopus -b:a 96k \
  `# faststart: moov atom을 앞으로 → 웹 스트리밍 즉시 재생` \
  -movflags +faststart \
  "$OUTPUT.tmp.mp4"

mv -vn "$OUTPUT.tmp.mp4" "$OUTPUT"

if [ "$DELETE_SOURCE" = "1" ]; then
  rm -v -- "$INPUT"
fi
